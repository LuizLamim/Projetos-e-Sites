       IDENTIFICATION DIVISION.
       PROGRAM-ID. CAIXA-ELETRONICO.
       AUTHOR. LUIZ LAMIM

       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       SPECIAL-NAMES.
       DECIMAL-POINT IS COMMA.

       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01  WS-CLIENTE.
           05 WS-NOME          PIC X(30) VALUE "JOAO DA SILVA".
           05 WS-SALDO         PIC 9(06)V99 VALUE 1000,00.
           05 WS-SALDO-TELA    PIC ZZZ.ZZ9,99.
           
       01  WS-OPERACAO-VAR.
           05 WS-VALOR-INPUT   PIC 9(06)V99 VALUE ZERO.
           05 WS-VALOR-TELA    PIC ZZZ.ZZ9,99.
           05 WS-OPCAO         PIC X VALUE SPACES.
           05 WS-MENSAGEM      PIC X(40) VALUE SPACES 

       SCREEN SECTION.
       01  TELA-PRINCIPAL.
           05 BLANK SCREEN.
           05 LINE 02 COL 25 VALUE "=== BANCO COBOL DIGITAL ===".
           05 LINE 04 COL 10 VALUE "CLIENTE: ".
           05 LINE 04 COL 20 PIC X(30) FROM WS-NOME.
           05 LINE 06 COL 10 VALUE "1 - VER SALDO".
           05 LINE 07 COL 10 VALUE "2 - DEPOSITAR".
           05 LINE 08 COL 10 VALUE "3 - SACAR".
           05 LINE 09 COL 10 VALUE "9 - SAIR".
           05 LINE 11 COL 10 VALUE "ESCOLHA A OPCAO: ".
           05 LINE 11 COL 27 PIC X TO WS-OPCAO AUTO.

       01  TELA-SALDO.
           05 BLANK SCREEN.
           05 LINE 02 COL 25 VALUE "=== CONSULTA DE SALDO ===".
           05 LINE 06 COL 15 VALUE "SEU SALDO ATUAL E: R$ ".
           05 LINE 06 COL 37 PIC ZZZ.ZZ9,99 FROM WS-SALDO.
           05 LINE 10 COL 15 VALUE "PRESSIONE ENTER PARA VOLTAR...".

       01  TELA-DEPOSITO.
           05 BLANK SCREEN.
           05 LINE 02 COL 25 VALUE "=== OPERACAO DE DEPOSITO ===".
           05 LINE 06 COL 15 VALUE "VALOR DO DEPOSITO: R$ ".
           05 LINE 06 COL 37 PIC 9(06)V99 TO WS-VALOR-INPUT.

       01  TELA-SAQUE.
           05 BLANK SCREEN.
           05 LINE 02 COL 25 VALUE "=== OPERACAO DE SAQUE ===".
           05 LINE 06 COL 15 VALUE "VALOR DO SAQUE: R$    ".
           05 LINE 06 COL 37 PIC 9(06)V99 TO WS-VALOR-INPUT.

       01  TELA-MENSAGEM.
           05 LINE 15 COL 15 PIC X(40) FROM WS-MENSAGEM FOREGROUND-COLOR 2.
           05 LINE 17 COL 15 VALUE "PRESSIONE ENTER PARA CONTINUAR...".

       PROCEDURE DIVISION.
       MAIN-PROCEDURE.
           PERFORM UNTIL WS-OPCAO = "9"
               DISPLAY TELA-PRINCIPAL
               ACCEPT TELA-PRINCIPAL
               
               EVALUATE WS-OPCAO
                   WHEN "1"
                       PERFORM DO-SALDO
                   WHEN "2"
                       PERFORM DO-DEPOSITO
                   WHEN "3"
                       PERFORM DO-SAQUE
                   WHEN "9"
                       DISPLAY "OBRIGADO POR UTILIZAR NOSSO BANCO!"
                   WHEN OTHER
                       MOVE "OPCAO INVALIDA!" TO WS-MENSAGEM
                       PERFORM MOSTRA-MENSAGEM
               END-EVALUATE
           END-PERFORM.
           STOP RUN.

       DO-SALDO.
           DISPLAY TELA-SALDO.
           ACCEPT WS-OPCAO.

       DO-DEPOSITO.
           MOVE ZERO TO WS-VALOR-INPUT.
           DISPLAY TELA-DEPOSITO.
           ACCEPT TELA-DEPOSITO.
           
           IF WS-VALOR-INPUT > ZERO
               ADD WS-VALOR-INPUT TO WS-SALDO
               MOVE "DEPOSITO REALIZADO COM SUCESSO!" TO WS-MENSAGEM
           ELSE
               MOVE "VALOR INVALIDO PARA DEPOSITO!" TO WS-MENSAGEM
           END-IF.
           PERFORM MOSTRA-MENSAGEM.

       DO-SAQUE.
           MOVE ZERO TO WS-VALOR-INPUT.
           DISPLAY TELA-SAQUE.
           ACCEPT TELA-SAQUE.
           
           IF WS-VALOR-INPUT > WS-SALDO
               MOVE "SALDO INSUFICIENTE!" TO WS-MENSAGEM
           ELSE
               IF WS-VALOR-INPUT > ZERO
                   SUBTRACT WS-VALOR-INPUT FROM WS-SALDO
                   MOVE "SAQUE REALIZADO COM SUCESSO!" TO WS-MENSAGEM
               ELSE
                   MOVE "VALOR INVALIDO PARA SAQUE!" TO WS-MENSAGEM
               END-IF
           END-IF.
           PERFORM MOSTRA-MENSAGEM.

       MOSTRA-MENSAGEM.
           DISPLAY TELA-MENSAGEM.
           ACCEPT WS-OPCAO.
           MOVE SPACES TO WS-MENSAGEM.